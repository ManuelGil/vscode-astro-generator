{
	"name": "vscode-astro-generator",
	"displayName": "Astro File Generator",
	"description": "👩‍🚀 Generate Astro components, pages, and layouts in seconds. Scaffold files from curated or custom templates with a fast, localized UX and seamless workspace support.",
	"version": "1.6.0",
	"icon": "icon.png",
	"license": "MIT",
	"publisher": "imgildev",
	"author": {
		"name": "Manuel Gil",
		"email": "support@imgil.dev",
		"url": "https://imgil.dev/"
	},
	"sponsor": {
		"url": "https://github.com/sponsors/manuelgil"
	},
	"packageManager": "pnpm@10.0.0",
	"engines": {
		"vscode": "^1.102.0",
		"node": ">=22.15.1"
	},
	"categories": [
		"Other"
	],
	"keywords": [
		"astro",
		"astrojs",
		"astro-generator",
		"astro-components",
		"astro-pages",
		"scaffold",
		"scaffolding",
		"code-generation",
		"templates",
		"boilerplate",
		"snippets",
		"frontmatter",
		"markdown",
		"typescript",
		"vscode-extension",
		"workspace"
	],
	"homepage": "https://github.com/ManuelGil/vscode-astro-generator",
	"repository": {
		"type": "git",
		"url": "https://github.com/ManuelGil/vscode-astro-generator"
	},
	"bugs": {
		"url": "https://github.com/ManuelGil/vscode-astro-generator/issues"
	},
	"activationEvents": [],
	"main": "./out/extension.js",
	"l10n": "./l10n",
	"files": [
		"out",
		"package*.json",
		"README.md",
		"LICENSE",
		"icon.png",
		"schemas",
		"l10n"
	],
	"contributes": {
		"configuration": {
			"title": "Astro File Generator",
			"properties": {
				"astroGenerator.enable": {
					"type": "boolean",
					"default": true,
					"scope": "resource",
					"description": "%astroGenerator.enable%"
				},
				"astroGenerator.files.include": {
					"type": "array",
					"default": [
						"astro"
					],
					"scope": "resource",
					"description": "%astroGenerator.files.include%"
				},
				"astroGenerator.files.exclude": {
					"type": "array",
					"default": [
						"**/node_modules/**",
						"**/dist/**",
						"**/out/**",
						"**/build/**",
						"**/.*/**"
					],
					"scope": "resource",
					"description": "%astroGenerator.files.exclude%"
				},
				"astroGenerator.files.showPath": {
					"type": "boolean",
					"default": true,
					"scope": "resource",
					"description": "%astroGenerator.files.showPath%"
				},
				"astroGenerator.files.skipFolderConfirmation": {
					"type": "boolean",
					"default": false,
					"scope": "resource",
					"description": "%astroGenerator.files.skipFolderConfirmation%"
				},
				"astroGenerator.formatting.headerCommentTemplate": {
					"type": "array",
					"default": [],
					"scope": "resource",
					"description": "%astroGenerator.formatting.headerCommentTemplate%"
				},
				"astroGenerator.formatting.insertFinalNewline": {
					"type": "boolean",
					"default": true,
					"scope": "resource",
					"description": "%astroGenerator.formatting.insertFinalNewline%"
				},
				"astroGenerator.templates.customComponents": {
					"type": "array",
					"default": [
						{
							"name": "Blog Post",
							"description": "A blog post template",
							"extension": "md",
							"template": [
								"---",
								"title: 'Title'",
								"description: 'Description'",
								"date: '2022-01-01'",
								"tags: ['tag1', 'tag2']",
								"---",
								"",
								"# Title",
								"",
								"Description",
								"",
								"## Subtitle",
								"",
								"Content"
							]
						}
					],
					"scope": "resource",
					"description": "%astroGenerator.templates.customComponents%"
				}
			}
		},
		"commands": [
			{
				"command": "astroGenerator.listComponents.refresh",
				"title": "%astroGenerator.listComponents.refresh%",
				"category": "Astro File Generator",
				"icon": "$(refresh)"
			},
			{
				"command": "astroGenerator.file.generateBasicPage",
				"title": "%astroGenerator.file.generateBasicPage%",
				"category": "Astro File Generator"
			},
			{
				"command": "astroGenerator.file.generateBasicComponent",
				"title": "%astroGenerator.file.generateBasicComponent%",
				"category": "Astro File Generator"
			},
			{
				"command": "astroGenerator.file.generateLayoutWithSlots",
				"title": "%astroGenerator.file.generateLayoutWithSlots%",
				"category": "Astro File Generator"
			},
			{
				"command": "astroGenerator.file.generateStaticDataPage",
				"title": "%astroGenerator.file.generateStaticDataPage%",
				"category": "Astro File Generator"
			},
			{
				"command": "astroGenerator.file.generatePageWithDataFetching",
				"title": "%astroGenerator.file.generatePageWithDataFetching%",
				"category": "Astro File Generator"
			},
			{
				"command": "astroGenerator.file.generateStyledComponent",
				"title": "%astroGenerator.file.generateStyledComponent%",
				"category": "Astro File Generator"
			},
			{
				"command": "astroGenerator.file.generateCustomComponent",
				"title": "%astroGenerator.file.generateCustomComponent%",
				"category": "Astro File Generator"
			},
			{
				"command": "astroGenerator.changeWorkspace",
				"title": "%astroGenerator.changeWorkspace.title%",
				"category": "Astro File Generator"
			}
		],
		"submenus": [
			{
				"id": "astroGenerator.folder.submenu",
				"label": "Astro File Generator"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "astroGenerator.listComponents.refresh",
					"when": "view == astroGenerator.listComponentsView",
					"group": "navigation"
				}
			],
			"explorer/context": [
				{
					"submenu": "astroGenerator.folder.submenu",
					"group": "2_workspace",
					"when": "explorerViewletFocus && explorerResourceIsFolder && !explorerResourceIsRoot"
				}
			],
			"astroGenerator.folder.submenu": [
				{
					"command": "astroGenerator.file.generateBasicPage",
					"group": "1_generate@1"
				},
				{
					"command": "astroGenerator.file.generateBasicComponent",
					"group": "1_generate@2"
				},
				{
					"command": "astroGenerator.file.generateLayoutWithSlots",
					"group": "1_generate@3"
				},
				{
					"command": "astroGenerator.file.generateStaticDataPage",
					"group": "1_generate@4"
				},
				{
					"command": "astroGenerator.file.generatePageWithDataFetching",
					"group": "1_generate@5"
				},
				{
					"command": "astroGenerator.file.generateStyledComponent",
					"group": "1_generate@6"
				},
				{
					"command": "astroGenerator.file.generateCustomComponent",
					"group": "1_generate@7"
				}
			]
		},
		"viewsWelcome": [
			{
				"view": "astroGenerator.listComponentsView",
				"contents": "%viewsWelcome.astroGenerator.listFilesView%"
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "astro-explorer",
					"title": "Astro File Generator",
					"icon": "./icon.svg"
				}
			]
		},
		"views": {
			"astro-explorer": [
				{
					"id": "astroGenerator.integrationsView",
					"name": "%views.astroGenerator.integrationsView%",
					"type": "webview"
				},
				{
					"id": "astroGenerator.listComponentsView",
					"name": "%views.astroGenerator.listComponentsView%",
					"visibility": "visible"
				},
				{
					"id": "astroGenerator.feedbackView",
					"name": "%views.astroGenerator.feedbackView%",
					"visibility": "visible"
				}
			]
		},
		"jsonValidation": [
			{
				"fileMatch": ".vscode/settings.json",
				"url": "./schemas/config.schema.json"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "pnpm compile",
		"typecheck": "tsc --noEmit -p ./",
		"compile": "pnpm typecheck && rimraf out && esbuild src/extension.ts --bundle --platform=node --target=node22 --format=cjs --external:vscode --outfile=out/extension.js && cpy \"assets/**/*\" out/assets",
		"watch": "tsc -watch -p ./",
		"pretest": "pnpm compile && tsc -p ./ && pnpm lint",
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"check": "biome check .",
		"check:fix": "biome check --write --unsafe .",
		"test": "vscode-test",
		"test:unit": "mocha -r ts-node/register src/**/*.test.ts",
		"l10n:check": "node scripts/check-l10n.js",
		"nls:check": "node scripts/check-nls.js",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"@tailwindcss/postcss": "^4.3.1",
		"@types/mocha": "^10.0.10",
		"@types/node": "^22.19.21",
		"@types/vscode": "^1.102.0",
		"@vscode/l10n-dev": "^0.0.35",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"autoprefixer": "^10.5.0",
		"cpy-cli": "^6.0.0",
		"esbuild": "^0.28.1",
		"glob": "^11.1.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"mocha": "^11.7.6",
		"postcss": "^8.5.15",
		"rimraf": "^6.1.3",
		"tailwindcss": "^4.3.1",
		"typescript": "^5.9.3",
		"vite": "^7.3.5"
	},
	"dependencies": {
		"@vscode/codicons": "^0.0.45",
		"alpinejs": "^3.15.12",
		"p-limit": "^7.3.0",
		"vscode-marketplace-client": "^1.2.4"
	},
	"pnpm": {
		"overrides": {
			"diff@>=6.0.0 <8.0.3": ">=8.0.3",
			"serialize-javascript@>=5.0.0 <7.0.5": ">=7.0.5"
		},
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
